{
  "name": "@rslint/native",
  "version": "0.0.0",
  "private": true,
  "description": "Build-only napi config and Rust sources for the rslint native parser. Not published — the compiled .node ships in the @rslint/native-<tuple> platform packages.",
  "napi": {
    "binaryName": "rslint",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --no-js && node ../../scripts/place-host-build.mjs node",
    "build:debug": "napi build --platform --no-js && node ../../scripts/place-host-build.mjs node"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2"
  }
}
