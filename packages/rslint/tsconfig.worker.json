{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "types": ["node"],
    "tsBuildInfoFile": "${configDir}/node_modules/.cache/rslint-core-worker-dts.tsbuildinfo"
  },
  "include": [
    "${configDir}/src/eslint-plugin/**/*.ts",
    "${configDir}/src/config/plugin-source.ts"
  ],
  "exclude": [
    "${configDir}/src/eslint-plugin/**/*.spec.ts",
    "${configDir}/src/eslint-plugin/**/*.test.ts"
  ]
}
