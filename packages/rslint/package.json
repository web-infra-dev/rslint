{
  "name": "@rslint/core",
  "version": "0.7.0",
  "exports": {
    ".": {
      "@typescript/source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./service": {
      "@typescript/source": "./src/service/service.ts",
      "default": "./dist/service.js"
    },
    "./internal": {
      "@typescript/source": "./src/internal/node.ts",
      "default": "./dist/internal.js"
    },
    "./config-loader": {
      "@typescript/source": "./src/config/config-loader.ts",
      "default": "./dist/config-loader.js"
    },
    "./eslint-plugin": {
      "@typescript/source": "./src/eslint-plugin/index.ts",
      "default": "./dist/eslint-plugin/index.js"
    },
    "./bin": "./bin/rslint.js",
    "./package.json": "./package.json"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rslint"
  },
  "scripts": {
    "build:bin": "node ../../scripts/place-host-build.mjs bin",
    "build:debug": "node ../../scripts/place-host-build.mjs bin --debug",
    "build:js": "rslib build",
    "dev": "rslib build --watch",
    "build": "pnpm build:bin && pnpm build:js",
    "test": "rstest run",
    "test:update": "rstest run -u"
  },
  "files": [
    "bin/rslint.js",
    "dist/"
  ],
  "bin": {
    "rslint": "./bin/rslint.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "description": "rslint core library",
  "publisher": "rslint",
  "keywords": [
    "rslint",
    "linter",
    "typescript",
    "go"
  ],
  "devDependencies": {
    "@eslint/plugin-kit": "0.7.2",
    "@rslib/core": "1.0.0-beta.1",
    "@rslint/api": "workspace:*",
    "@types/node": "24.0.14",
    "@types/picomatch": "4.0.2",
    "@typescript-eslint/scope-manager": "8.59.4",
    "@typescript-eslint/visitor-keys": "8.59.4",
    "@typescript/native-preview": "7.0.0-dev.20250904.1",
    "eslint-scope": "9.1.2",
    "eslint-visitor-keys": "5.0.1",
    "espree": "11.2.0",
    "esquery": "1.7.0",
    "globals": "17.7.0",
    "tinyglobby": "0.2.15",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "jiti": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@rslint/native-darwin-arm64": "workspace:*",
    "@rslint/native-darwin-x64": "workspace:*",
    "@rslint/native-linux-arm64-gnu": "workspace:*",
    "@rslint/native-linux-x64-gnu": "workspace:*",
    "@rslint/native-linux-arm64-musl": "workspace:*",
    "@rslint/native-linux-x64-musl": "workspace:*",
    "@rslint/native-win32-arm64-msvc": "workspace:*",
    "@rslint/native-win32-x64-msvc": "workspace:*"
  },
  "dependencies": {
    "picomatch": "4.0.4"
  }
}
