{
  "name": "@rslint/eslint-plugin-runner",
  "version": "0.5.3",
  "description": "ESLint-plugin compatibility runtime for rslint — Worker pool, per-file lint pipeline, scope manager. Embedded by the CLI (@rslint/core) and by the VS Code extension; not invoked as a standalone process.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-infra-dev/rslint.git",
    "directory": "packages/eslint-plugin-runner"
  },
  "license": "MIT",
  "publisher": "rslint",
  "keywords": [
    "rslint",
    "eslint",
    "eslint-plugin",
    "linter",
    "internal"
  ],
  "exports": {
    ".": {
      "@typescript/source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./ipc-client": {
      "@typescript/source": "./src/ipc-client.ts",
      "default": "./dist/ipc-client.js"
    },
    "./types": {
      "@typescript/source": "./src/types.ts",
      "default": "./dist/types.js"
    },
    "./plugin-source": {
      "@typescript/source": "./src/plugin-source.ts",
      "default": "./dist/plugin-source.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rslib build",
    "test": "rstest run"
  },
  "devDependencies": {
    "@eslint/plugin-kit": "0.3.5",
    "@rslib/core": "0.21.2",
    "@rstest/core": "0.9.2",
    "@types/node": "24.0.14",
    "espree": "11.2.0"
  },
  "dependencies": {
    "@typescript-eslint/scope-manager": "8.59.4",
    "eslint-scope": "9.1.2",
    "esquery": "1.7.0",
    "globals": "17.6.0",
    "oxc-parser": "0.132.0"
  },
  "peerDependencies": {
    "jiti": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  }
}
