{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "Fragment",
    "target": "es2015",
    "module": "commonjs",
    "moduleDetection": "force",
    "strict": true,
    "esModuleInterop": true,
    "lib": ["es2015", "es2017", "esnext", "DOM"],
    "types": [],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "react.tsx"
  ]
}
