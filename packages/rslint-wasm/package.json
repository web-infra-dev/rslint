{
  "name": "@rslint/wasm",
  "version": "0.7.1",
  "description": "rslint wasm package",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:wasm": "cross-env GOOS=js GOARCH=wasm go build  -o rslint.wasm -ldflags=\"-s -w\"  ../../cmd/rslint",
    "build:wasm:gz": "node scripts/gzip-wasm.mjs",
    "build:js": "node scripts/build.mjs && tsgo -b tsconfig.json",
    "build": "pnpm run build:wasm && pnpm run build:wasm:gz && pnpm run build:js"
  },
  "files": [
    "dist/index.mjs",
    "dist/**.d.ts",
    "rslint.wasm",
    "rslint.wasm.gz"
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rslint"
  },
  "packageManager": "pnpm@10.34.4",
  "devDependencies": {
    "@rslint/core": "workspace:*",
    "@microsoft/api-extractor": "catalog:build",
    "@wasmer/wasmfs": "catalog:wasm",
    "esbuild": "catalog:build",
    "buffer": "catalog:wasm",
    "cross-env": "catalog:wasm",
    "esbuild-plugin-polyfill-node": "catalog:wasm",
    "memfs": "catalog:wasm",
    "prebundle": "catalog:wasm",
    "typescript": "catalog:types"
  },
  "dependencies": {
    "@rslint/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
